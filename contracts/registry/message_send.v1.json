{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "message_send v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "user_id",
    "surface",
    "message_id",
    "thread_id",
    "char_count"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "message_send" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "user_id": { "type": "string" },
    "surface": {
      "type": "string",
      "enum": ["feed", "reels", "stories", "messaging", "ads", "notifications"]
    },
    "message_id": { "type": "string" },
    "thread_id": { "type": "string" },
    "char_count": { "type": "integer", "minimum": 1 }
  }
}
