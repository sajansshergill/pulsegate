{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ad_click v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "user_id",
    "surface",
    "ad_id",
    "campaign_id",
    "impression_id"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "const": "ad_click" },
    "event_version": { "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "user_id": { "type": "string" },
    "surface": {
      "type": "string",
      "enum": ["feed", "reels", "stories", "messaging", "ads", "notifications"]
    },
    "ad_id": { "type": "string" },
    "campaign_id": { "type": "string" },
    "impression_id": { "type": "string" }
  }
}
